# ===========================
# AiFarcaster Environment Variables
# ===========================

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Stripe (optional - for fiat payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Crypto Payments
NEXT_PUBLIC_PAYMENT_RECEIVER_ADDRESS=0x...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Database (for Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/aifarcasters

# Auth
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
JWT_SECRET=generate_with_openssl_rand_base64_32

# OpenAI
OPENAI_API_KEY=sk-...

# Farcaster Hub
FARCASTER_HUB_URL=nemes.farcaster.xyz:2283

# Upstash Redis (for rate limiting)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Smart Contracts (Base chain)
NEXT_PUBLIC_PROMPT_NFT_ADDRESS=0x...
NEXT_PUBLIC_ACCESS_CONTROL_ADDRESS=0x...
DEPLOYER_PRIVATE_KEY=0x...

# Turborepo Remote Cache (optional)
TURBO_TOKEN=...
TURBO_TEAM=...
