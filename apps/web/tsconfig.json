{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{"name": "next"}],
    "paths": {
      "@/*": ["./*"],
      "@aifarcasters/core": ["../../packages/core/src/index.ts"],
      "@aifarcasters/ui": ["../../packages/ui/src/index.ts"],
      "@aifarcasters/auth": ["../../packages/auth/src/index.ts"],
      "@aifarcasters/web3": ["../../packages/web3/src/index.ts"]
    },
    "target": "ES2017"
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
